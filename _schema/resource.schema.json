{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/riscv-international/rvi-education-central/_schema/resource.schema.json",
  "title": "resource.yml",
  "description": "Descriptor at the root of a resources/<institution-slug>/ directory.",
  "type": "object",
  "additionalProperties": false,
  "required": ["institution", "maintainers"],
  "properties": {
    "institution": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Must equal the directory name and have a matching entry in institutions.yml."
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "github": { "type": "string", "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?$" },
          "email": { "type": "string", "format": "email" }
        }
      }
    },
    "default_license": {
      "type": "string",
      "enum": ["CC-BY-4.0", "CC-BY-SA-4.0", "MIT", "Apache-2.0", "BSD-3-Clause", "none"],
      "description": "Inherited by courses and assets that omit their own license. Falls back to the repository-wide default (CC-BY-SA-4.0) if omitted here too."
    }
  }
}
